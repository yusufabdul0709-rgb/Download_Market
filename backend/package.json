{
  "name": "download-market-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Download Market – download videos, reels, posts and audio from YouTube, Facebook & Instagram",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "worker": "node src/workers/ytdlp.worker.js",
    "keepalive": "node keepAlive.js",
    "postinstall": "node scripts/download-ytdlp.js",
    "lint": "eslint .",
    "test": "jest --testPathPatterns=tests/ --forceExit"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"]
  },
  "dependencies": {
    "@bochilteam/scraper": "^5.0.1",
    "@distube/ytdl-core": "^4.16.12",
    "@sasmeee/igdl": "^0.0.1-security",
    "archiver": "^7.0.1",
    "axios": "^1.15.0",
    "btch-downloader": "^6.0.26",
    "bullmq": "^5.58.5",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.1.0",
    "fb-downloader-scrapper": "^3.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "helmet": "^7.1.0",
    "https-proxy-agent": "^7.0.6",
    "ioredis": "^5.8.0",
    "morgan": "^1.10.0",
    "node-cron": "^3.0.3",
    "p-queue": "^8.1.1",
    "rate-limit-redis": "^4.3.1",
    "ruhend-scraper": "^10.0.1",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "yt-dlp-wrap": "^2.3.12"
  },
  "devDependencies": {
    "jest": "^30.3.0",
    "nodemon": "^3.1.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
