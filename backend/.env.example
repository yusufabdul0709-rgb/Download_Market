# ─────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─────────────────────────────────────────────
# CORS – comma-separated list of allowed origins
# ─────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to 1 if your Redis instance uses TLS (e.g. Redis Cloud)
REDIS_TLS=0

# ─────────────────────────────────────────────
# BullMQ / Queue
# ─────────────────────────────────────────────
QUEUE_NAME=downloadQueue
# Number of concurrent worker jobs
WORKER_CONCURRENCY=3

# ─────────────────────────────────────────────
# yt-dlp
# ─────────────────────────────────────────────
# Absolute path to the yt-dlp binary.
# Leave empty to rely on the system PATH.
YTDLP_PATH=yt-dlp

# ─────────────────────────────────────────────
# File Handling
# ─────────────────────────────────────────────
# Absolute (or relative) path to the temp directory
TEMP_DIR=./temp
# How long (seconds) a completed file lives before auto-deletion
FILE_TTL_SECONDS=900
# Max video duration allowed (seconds). 0 = unlimited.
MAX_DURATION_SECONDS=3600

# ─────────────────────────────────────────────
# Rate Limiting
# ─────────────────────────────────────────────
# Window in milliseconds
RATE_LIMIT_WINDOW_MS=60000
# Max requests per window per IP
RATE_LIMIT_MAX=30

# ─────────────────────────────────────────────
# Public base URL (used to build download links)
# ─────────────────────────────────────────────
BASE_URL=http://localhost:5000
